<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.IssuedReportController"
      spacing="16"
      style="-fx-background-color: #1e1e2e;">

    <!-- ── Header ── -->
    <Label text="Books Issued Report"
           style="-fx-text-fill: #cdd6f4; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Label text="Enter a date to view all books issued on that day."
           style="-fx-text-fill: #6c7086; -fx-font-size: 12px;"/>

    <!-- ── Date input row ── -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Date (DD/MM/YYYY):"
               style="-fx-text-fill: #cdd6f4; -fx-font-size: 13px;"/>
        <TextField fx:id="txtDate"
                   promptText="e.g. 18/04/2026"
                   prefWidth="160"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-background-radius: 6; -fx-padding: 6 10 6 10;"/>
        <Button text="Search" onAction="#searchIssued"
                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 16 6 16;"/>
    </HBox>

    <!-- ── Status ── -->
    <Label fx:id="lblStatus"
           style="-fx-text-fill: #f38ba8; -fx-font-size: 12px;"/>

    <Separator style="-fx-background-color: #45475a;"/>

    <!-- ── Results table ── -->
    <TableView fx:id="tblIssued" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #313244; -fx-border-color: #45475a; -fx-border-radius: 6;">
        <columns>
            <TableColumn fx:id="colDate"      text="Date"       prefWidth="100"/>
            <TableColumn fx:id="colBookId"    text="Book ID"/>
            <TableColumn fx:id="colTitle"     text="Title"      prefWidth="180"/>
            <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="100"/>
            <TableColumn fx:id="colStudent"   text="Student"    prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No results. Enter a date and click Search."
                   style="-fx-text-fill: #6c7086;"/>
        </placeholder>
    </TableView>

    <!-- ── Result count ── -->
    <Label fx:id="lblCount"
           style="-fx-text-fill: #a6e3a1; -fx-font-size: 12px;"/>

</VBox>
